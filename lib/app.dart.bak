class _MetroMarkerBadge extends StatelessWidget {
  const _MetroMarkerBadge({required this.marker, required this.selected});

  final MetroManilaMapMarkerSpec marker;
  final bool selected;

  @override
  Widget build(BuildContext context) {
    final color = _markerColor(marker.kind, selected);
    final icon = _markerIcon(marker.kind);

    return Container(
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 10),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(20),
        border: Border.all(
          color: selected ? AppColors.primary : AppColors.gray200,
        ),
        boxShadow: [
          BoxShadow(
            color: AppColors.gray600.withValues(alpha: selected ? 0.10 : 0.06),
            blurRadius: selected ? 14 : 10,
            offset: const Offset(0, 6),
          ),
        ],
      ),
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          Container(
            width: 34,
            height: 34,
            decoration: BoxDecoration(
              color: color,
              borderRadius: BorderRadius.circular(12),
            ),
            child: Icon(icon, size: 18, color: Colors.white),
          ),
          const SizedBox(height: 6),
          Text(
            marker.label,
            textAlign: TextAlign.center,
            style: Theme.of(context).textTheme.labelSmall?.copyWith(
              color: AppColors.ink,
              fontWeight: FontWeight.w700,
            ),
          ),
        ],
      ),
    );
  }
}

Color _markerColor(MetroManilaMapMarkerKind kind, bool selected) {
  if (selected) return AppColors.primary;
  switch (kind) {
    case MetroManilaMapMarkerKind.currentLocation:
      return AppColors.gray600;
    case MetroManilaMapMarkerKind.destination:
      return AppColors.primary;
    case MetroManilaMapMarkerKind.jeepney:
      return AppColors.gray600;
    case MetroManilaMapMarkerKind.terminal:
      return AppColors.gray400;
    case MetroManilaMapMarkerKind.busStop:
      return AppColors.gray400;
  }
}

IconData _markerIcon(MetroManilaMapMarkerKind kind) {
  switch (kind) {
    case MetroManilaMapMarkerKind.currentLocation:
      return Symbols.my_location_rounded;
    case MetroManilaMapMarkerKind.destination:
      return Symbols.flag_rounded;
    case MetroManilaMapMarkerKind.jeepney:
      return Symbols.directions_bus_rounded;
    case MetroManilaMapMarkerKind.terminal:
      return Symbols.place_rounded;
    case MetroManilaMapMarkerKind.busStop:
      return Symbols.stop_circle_rounded;
  }
}

String _markerDescription(MetroManilaMapMarkerKind kind) {
  switch (kind) {
    case MetroManilaMapMarkerKind.currentLocation:
      return 'Current location';
    case MetroManilaMapMarkerKind.destination:
      return 'Destination marker';
    case MetroManilaMapMarkerKind.jeepney:
      return 'Mock jeepney position';
    case MetroManilaMapMarkerKind.terminal:
      return 'Terminal stop';
    case MetroManilaMapMarkerKind.busStop:
      return 'Bus stop';
  }
}


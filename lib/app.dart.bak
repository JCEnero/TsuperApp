class OnboardingScreen extends StatefulWidget {
  const OnboardingScreen({super.key});

  @override
  State<OnboardingScreen> createState() => _OnboardingScreenState();
}

class _OnboardingScreenState extends State<OnboardingScreen> {
  final PageController _controller = PageController();
  int _index = 0;

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: SafeArea(
        child: Column(
          children: [
            Padding(
              padding: const EdgeInsets.all(24),
              child: Row(
                mainAxisAlignment: MainAxisAlignment.spaceBetween,
                children: [
                  const BrandMark(),
                  TextButton(
                    onPressed:
                        () => Navigator.pushReplacementNamed(
                          context,
                          AppRoutes.roleSelection,
                        ),
                    child: const Text('Skip'),
                  ),
                ],
              ),
            ),
            Expanded(
              child: PageView.builder(
                controller: _controller,
                itemCount: AppData.onboardingSlides.length,
                onPageChanged: (value) => setState(() => _index = value),
                itemBuilder:
                    (context, index) => Padding(
                      padding: const EdgeInsets.symmetric(horizontal: 24),
                      child: OnboardingCard(
                        slide: AppData.onboardingSlides[index],
                      ),
                    ),
              ),
            ),
            Padding(
              padding: const EdgeInsets.fromLTRB(24, 0, 24, 24),
              child: Column(
                children: [
                  Row(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: List.generate(AppData.onboardingSlides.length, (
                      dotIndex,
                    ) {
                      final selected = _index == dotIndex;
                      return AnimatedContainer(
                        duration: const Duration(milliseconds: 250),
                        margin: const EdgeInsets.symmetric(horizontal: 4),
                        width: selected ? 24 : 8,
                        height: 8,
                        decoration: BoxDecoration(
                          color:
                              selected ? AppColors.primary : AppColors.gray200,
                          borderRadius: BorderRadius.circular(999),
                        ),
                      );
                    }),
                  ),
                  const SizedBox(height: 20),
                  PrimaryButton(
                    text:
                        _index == AppData.onboardingSlides.length - 1
                            ? 'Get Started'
                            : 'Continue',
                    icon: Symbols.arrow_forward_rounded,
                    onPressed: () {
                      if (_index < AppData.onboardingSlides.length - 1) {
                        _controller.nextPage(
                          duration: const Duration(milliseconds: 300),
                          curve: Curves.easeOutCubic,
                        );
                      } else {
                        Navigator.pushReplacementNamed(
                          context,
                          AppRoutes.roleSelection,
                        );
                      }
                    },
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }
}

class RoleSelectionScreen extends StatefulWidget {
  const RoleSelectionScreen({super.key});

  @override
  State<RoleSelectionScreen> createState() => _RoleSelectionScreenState();
}

class _RoleSelectionScreenState extends State<RoleSelectionScreen> {
  int? selectedIndex;

  Future<void> _chooseRole(int index, String route) async {
    setState(() => selectedIndex = index);
    await Future<void>.delayed(const Duration(milliseconds: 160));
    if (!mounted) return;
    Navigator.pushReplacementNamed(context, route);
  }

  @override
  Widget build(BuildContext context) {
    final viewInsets = MediaQuery.of(context).viewInsets.bottom;

    return Scaffold(
      body: SafeArea(
        child: LayoutBuilder(
          builder: (context, constraints) {
            final isWide = constraints.maxWidth >= 760;
            final roleCardWidth =
                isWide ? ((constraints.maxWidth - 48 - 14) / 2).clamp(280.0, 420.0) : constraints.maxWidth - 48;

            return SingleChildScrollView(
              keyboardDismissBehavior: ScrollViewKeyboardDismissBehavior.onDrag,
              padding: EdgeInsets.fromLTRB(24, 20, 24, 24 + viewInsets),
              child: Center(
                child: ConstrainedBox(
                  constraints: const BoxConstraints(maxWidth: 900),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.stretch,
                    children: [
                      const BrandMark(),
                      const SizedBox(height: 24),
                      Text(
                        'Choose your role',
                        style: Theme.of(context).textTheme.headlineMedium?.copyWith(
                          fontWeight: FontWeight.w700,
                        ),
                      ),
                      const SizedBox(height: 8),
                      Text(
                        'Start with a tailored commuter or driver experience.',
                        style: Theme.of(context).textTheme.bodyMedium?.copyWith(
                          color: AppColors.softInk,
                        ),
                      ),
                      const SizedBox(height: 20),
                      const IllustrationPlaceholder(
                        label: 'Role Illustration Placeholder',
                        icon: Symbols.badge_rounded,
                      ),
                      const SizedBox(height: 16),
                      Wrap(
                        spacing: 14,
                        runSpacing: 14,
                        children: [
                          SizedBox(
                            width: roleCardWidth,
                            height: 194,
                            child: RoleCard(
                              title: 'Passenger',
                              subtitle:
                                  'Search routes, view jeepneys, and save destinations.',
                              icon: Symbols.person_rounded,
                              selected: selectedIndex == 0,
                              onTap: () => _chooseRole(0, AppRoutes.passenger),
                            ),
                          ),
                          SizedBox(
                            width: roleCardWidth,
                            height: 194,
                            child: RoleCard(
                              title: 'Driver',
                              subtitle:
                                  'Track trips, monitor occupancy, and review shift stats.',
                              icon: Symbols.directions_bus_rounded,
                              selected: selectedIndex == 1,
                              onTap: () => _chooseRole(1, AppRoutes.driver),
                            ),
                          ),
                        ],
                      ),
                      const SizedBox(height: 18),
                      Wrap(
                        spacing: 10,
                        runSpacing: 10,
                        children: [
                          SizedBox(
                            width: isWide ? 150 : constraints.maxWidth - 48,
                            child: SecondaryButton(
                              text: 'Login',
                              onPressed: () => Navigator.pushNamed(context, AppRoutes.login),
                            ),
                          ),
                          SizedBox(
                            width: isWide ? 150 : constraints.maxWidth - 48,
                            child: SecondaryButton(
                              text: 'Register',
                              onPressed: () => Navigator.pushNamed(context, AppRoutes.register),
                            ),
                          ),
                          SizedBox(
                            width: isWide ? 190 : constraints.maxWidth - 48,
                            child: SecondaryButton(
                              text: 'Forgot Password',
                              onPressed: () => Navigator.pushNamed(context, AppRoutes.forgotPassword),
                            ),
                          ),
                        ],
                      ),
                    ],
                  ),
                ),
              ),
            );
          },
        ),
      ),
    );
  }
}

class FrostedNavigationBar extends StatelessWidget {

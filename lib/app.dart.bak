class AuthFormCard extends StatelessWidget {
  const AuthFormCard({super.key, required this.mode});

  final String mode;

  @override
  Widget build(BuildContext context) {
    return GlassCard(
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.stretch,
        children: [
          if (mode == 'Register') ...[
            const _TextFieldPlaceholder(label: 'Full name'),
            const SizedBox(height: 12),
          ],
          const _TextFieldPlaceholder(label: 'Email or mobile number'),
          const SizedBox(height: 12),
          if (mode != 'Forgot Password') ...[
            const _TextFieldPlaceholder(label: 'Password'),
            const SizedBox(height: 8),
          ],
          if (mode == 'Register') ...[
            const _TextFieldPlaceholder(label: 'Confirm password'),
            const SizedBox(height: 8),
          ],
          if (mode == 'Login')
            Align(
              alignment: Alignment.centerLeft,
              child: TextButton(
                onPressed:
                    () =>
                        Navigator.pushNamed(context, AppRoutes.forgotPassword),
                child: const Text('Forgot Password?'),
              ),
            ),
          if (mode == 'Forgot Password') ...[
            const SizedBox(height: 6),
            Text(
              'We will send a reset link to the email address above.',
              style: Theme.of(context).textTheme.bodySmall?.copyWith(
                color: AppColors.softInk,
                height: 1.45,
              ),
            ),
            const SizedBox(height: 14),
          ] else ...[
            const SizedBox(height: 8),
          ],
          PrimaryButton(
            text:
                mode == 'Forgot Password'
                    ? 'Send Reset Link'
                    : mode == 'Register'
                    ? 'Create Account'
                    : 'Login',
            icon: Symbols.arrow_forward_rounded,
            onPressed:
                () => Navigator.pushReplacementNamed(
                  context,
                  AppRoutes.roleSelection,
                ),
          ),
          if (mode == 'Register') ...[
            const SizedBox(height: 8),
            Align(
              alignment: Alignment.center,
              child: TextButton(
                onPressed: () => Navigator.pushNamed(context, AppRoutes.login),
                child: const Text('Already have an account? Login'),
              ),
            ),
          ],
          if (mode == 'Forgot Password') ...[
            const SizedBox(height: 8),
            Align(
              alignment: Alignment.center,
              child: TextButton(
                onPressed: () => Navigator.pushNamed(context, AppRoutes.login),
                child: const Text('Back to Login'),
              ),
            ),
          ],
        ],
      ),
    );
  }
}

class _TextFieldPlaceholder extends StatelessWidget {
  const _TextFieldPlaceholder({required this.label});

  final String label;

  @override
  Widget build(BuildContext context) {
    return TextField(
      decoration: InputDecoration(
        labelText: label,
        filled: true,
        fillColor: Colors.white,
        border: OutlineInputBorder(borderRadius: BorderRadius.circular(16)),
        enabledBorder: OutlineInputBorder(
          borderRadius: BorderRadius.circular(16),
          borderSide: BorderSide(color: AppColors.gray200),
        ),
        focusedBorder: OutlineInputBorder(
          borderRadius: BorderRadius.circular(16),
          borderSide: const BorderSide(color: AppColors.primary, width: 1.2),
        ),
      ),
    );
  }
}


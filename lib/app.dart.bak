IconData _notificationIcon(NotificationKind kind) {
  switch (kind) {
    case NotificationKind.announcement:
      return Symbols.campaign_rounded;
    case NotificationKind.route:
      return Symbols.route_rounded;
    case NotificationKind.alert:
      return Symbols.warning_rounded;
    case NotificationKind.promo:
      return Symbols.local_offer_rounded;
    case NotificationKind.system:
      return Symbols.system_update_alt_rounded;
  }
}

enum NotificationKind { announcement, route, alert, promo, system }

enum MapMode { passenger, driver }


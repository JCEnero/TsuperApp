class MetroManilaMapExplorer extends StatefulWidget {
  const MetroManilaMapExplorer({
    super.key,
    required this.initialRouteId,
    this.showDriverActions = false,
  });

  final String initialRouteId;
  final bool showDriverActions;

  @override
  State<MetroManilaMapExplorer> createState() => _MetroManilaMapExplorerState();
}

class _MetroManilaMapExplorerState extends State<MetroManilaMapExplorer>
    with TickerProviderStateMixin {
  static final LatLngBounds _metroManilaBounds = LatLngBounds(
    const LatLng(14.36, 120.84),
    const LatLng(14.81, 121.18),
  );

  late final AnimatedMapController _animatedMapController =
      AnimatedMapController(
        vsync: this,
        duration: const Duration(milliseconds: 520),
        curve: Curves.easeInOutCubic,
        cancelPreviousAnimations: true,
      );

  late MetroManilaRoute _selectedRoute;
  String? _selectedMarkerId;

  @override
  void initState() {
    super.initState();
    _selectedRoute = AppData.metroManilaRoutes.firstWhere(
      (route) => route.id == widget.initialRouteId,
      orElse: () => AppData.metroManilaRoutes.first,
    );
    _selectedMarkerId = _selectedRoute.markers.first.id;
  }

  @override
  void dispose() {
    _animatedMapController.dispose();
    super.dispose();
  }

  MetroManilaMapMarkerSpec? get _selectedMarker {
    for (final marker in _selectedRoute.markers) {
      if (marker.id == _selectedMarkerId) return marker;
    }
    return null;
  }

  Future<void> _selectRoute(MetroManilaRoute route) async {
    if (route.id == _selectedRoute.id) return;
    setState(() {
      _selectedRoute = route;
      _selectedMarkerId = route.markers.first.id;
    });
    await _animatedMapController.animatedFitCamera(
      cameraFit: CameraFit.coordinates(
        coordinates: route.path,
        padding: const EdgeInsets.all(72),
      ),
      customId: route.id,
      duration: const Duration(milliseconds: 500),
      curve: Curves.easeInOutCubic,
    );
  }

  Future<void> _focusMarker(MetroManilaMapMarkerSpec marker) async {
    setState(() => _selectedMarkerId = marker.id);
    await _animatedMapController.animateTo(
      dest: marker.point,
      zoom: (_selectedRoute.zoom + 0.35).clamp(11.0, 16.5),
      customId: marker.id,
      duration: const Duration(milliseconds: 420),
      curve: Curves.easeOutCubic,
    );
  }

  void _zoomIn() {
    _animatedMapController.animatedZoomIn(
      customId: 'metro-map-zoom',
      duration: const Duration(milliseconds: 280),
      curve: Curves.easeOutCubic,
    );
  }

  void _zoomOut() {
    _animatedMapController.animatedZoomOut(
      customId: 'metro-map-zoom',
      duration: const Duration(milliseconds: 280),
      curve: Curves.easeOutCubic,
    );
  }

  Future<void> _fitSelectedRoute() {
    return _animatedMapController.animatedFitCamera(
      cameraFit: CameraFit.coordinates(
        coordinates: _selectedRoute.path,
        padding: const EdgeInsets.all(72),
      ),
      customId: 'metro-map-fit',
      duration: const Duration(milliseconds: 500),
      curve: Curves.easeInOutCubic,
    );
  }

  @override
  Widget build(BuildContext context) {
    final selectedRoute = _selectedRoute;
    final selectedMarker = _selectedMarker;

    return Column(
      crossAxisAlignment: CrossAxisAlignment.stretch,
      children: [
        SearchBarCard(
          placeholder: 'Search QCU, SM Fairview, Cubao, or Novaliches',
        ),
        const SizedBox(height: 12),
        SizedBox(
          height: 42,
          child: ListView.separated(
            scrollDirection: Axis.horizontal,
            itemCount: AppData.metroManilaRoutes.length,
            separatorBuilder: (_, __) => const SizedBox(width: 10),
            itemBuilder: (context, index) {
              final route = AppData.metroManilaRoutes[index];
              final selected = route.id == selectedRoute.id;
              return _RouteChip(
                route: route,
                selected: selected,
                onTap: () => _selectRoute(route),
              );
            },
          ),
        ),
        const SizedBox(height: 14),
        Expanded(
          child: ClipRRect(
            borderRadius: BorderRadius.circular(28),
            child: Container(
              decoration: BoxDecoration(
                color: Colors.white,
                borderRadius: BorderRadius.circular(28),
                border: Border.all(color: AppColors.gray200),
                boxShadow: [
                  BoxShadow(
                    color: AppColors.gray600.withValues(alpha: 0.05),
                    blurRadius: 18,
                    offset: const Offset(0, 8),
                  ),
                ],
              ),
              child: Stack(
                children: [
                  FlutterMap(
                    mapController: _animatedMapController.mapController,
                    options: MapOptions(
                      initialCenter: selectedRoute.center,
                      initialZoom: selectedRoute.zoom,
                      minZoom: 11,
                      maxZoom: 16.5,
                      cameraConstraint: CameraConstraint.contain(
                        bounds: _metroManilaBounds,
                      ),
                      interactionOptions: const InteractionOptions(
                        flags: InteractiveFlag.all,
                      ),
                      onTap: (_, __) {
                        setState(
                          () => _selectedMarkerId = selectedRoute.markers.first.id,
                        );
                      },
                    ),
                    children: [
                      TileLayer(
                        urlTemplate:
                            'https://stamen-tiles.a.ssl.fastly.net/toner-lite/{z}/{x}/{y}.png',
                        userAgentPackageName: 'tsuper_app',
                        maxNativeZoom: 16,
                      ),
                      AnimatedSwitcher(
                        duration: const Duration(milliseconds: 260),
                        switchInCurve: Curves.easeOutCubic,
                        switchOutCurve: Curves.easeInCubic,
                        transitionBuilder: (child, animation) {
                          return FadeTransition(opacity: animation, child: child);
                        },
                        child: PolylineLayer(
                          key: ValueKey('poly-${selectedRoute.id}'),
                          polylines: [
                            Polyline(
                              points: selectedRoute.path,
                              color: AppColors.primary,
                              strokeWidth: 6,
                              strokeCap: StrokeCap.round,
                              strokeJoin: StrokeJoin.round,
                            ),
                          ],
                        ),
                      ),
                      AnimatedMarkerLayer(
                        markers:
                            selectedRoute.markers
                                .map(
                                  (marker) => AnimatedMarker(
                                    point: marker.point,
                                    width: 88,
                                    height: 88,
                                    duration: const Duration(milliseconds: 280),
                                    curve: Curves.easeOutCubic,
                                    builder: (context, animation) {
                                      final selected = _selectedMarkerId == marker.id;
                                      return GestureDetector(
                                        onTap: () => _focusMarker(marker),
                                        child: Opacity(
                                          opacity: animation.value,
                                          child: Transform.translate(
                                            offset: Offset(
                                              0,
                                              (1 - animation.value) * 12,
                                            ),
                                            child: Transform.scale(
                                              scale: 0.94 + (animation.value * 0.06),
                                              child: _MetroMarkerBadge(
                                                marker: marker,
                                                selected: selected,
                                              ),
                                            ),
                                          ),
                                        ),
                                      );
                                    },
                                  ),
                                )
                                .toList(),
                      ),
                    ],
                  ),
                  Positioned(
                    left: 16,
                    top: 16,
                    child: _MapSurfaceTag(
                      title: 'Metro Manila',
                      subtitle: 'Mock grayscale map',
                    ),
                  ),
                  Positioned(
                    top: 16,
                    right: 16,
                    child: _MapZoomControls(
                      onZoomIn: _zoomIn,
                      onZoomOut: _zoomOut,
                      onFit: _fitSelectedRoute,
                    ),
                  ),
                  Positioned(
                    left: 16,
                    right: 16,
                    bottom: 16,
                    child: AnimatedSwitcher(
                      duration: const Duration(milliseconds: 260),
                      switchInCurve: Curves.easeOutCubic,
                      switchOutCurve: Curves.easeInCubic,
                      transitionBuilder: (child, animation) {
                        return SlideTransition(
                          position: Tween<Offset>(
                            begin: const Offset(0, 0.08),
                            end: Offset.zero,
                          ).animate(animation),
                          child: FadeTransition(opacity: animation, child: child),
                        );
                      },
                      child: _MapRouteSheet(
                        key: ValueKey('${selectedRoute.id}-${selectedMarker?.id}'),
                        route: selectedRoute,
                        selectedMarker: selectedMarker,
                      ),
                    ),
                  ),
                ],
              ),
            ),
          ),
        ),
        if (widget.showDriverActions) ...[
          const SizedBox(height: 12),
          Text(
            'Driver focus mode',
            style: Theme.of(context).textTheme.labelLarge?.copyWith(
              color: AppColors.softInk,
              fontWeight: FontWeight.w700,
            ),
          ),
        ],
      ],
    );
  }
}

class _RouteChip extends StatelessWidget {

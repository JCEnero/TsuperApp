# ─────────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# SUPABASE
# Get these from: Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────

# Allowed origin for CORS (your Flutter app's domain in production)
# Use * for development, specific domain for production
CORS_ORIGIN=*

# General rate limit: max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth rate limit: stricter limit for login/signup/password endpoints
AUTH_RATE_LIMIT_MAX=10
